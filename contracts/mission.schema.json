{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erasmus.local/contracts/mission-v1.json",
  "title": "Erasmus bounded mission contract",
  "type": "object",
  "required": [
    "version", "title", "objective", "success_conditions", "constraints",
    "authority_envelope", "allowed_capabilities", "evidence_requirements",
    "risk_class", "stopping_condition", "rollback_plan", "steps"
  ],
  "properties": {
    "version": {"const": "1.0.0"},
    "title": {"$ref": "#/$defs/nonempty"},
    "objective": {"$ref": "#/$defs/nonempty"},
    "success_conditions": {"$ref": "#/$defs/stringList"},
    "constraints": {"$ref": "#/$defs/stringList"},
    "authority_envelope": {"$ref": "#/$defs/stringList"},
    "allowed_capabilities": {"$ref": "#/$defs/stringList"},
    "evidence_requirements": {"$ref": "#/$defs/stringList"},
    "risk_class": {"enum": ["low", "medium", "high", "irreversible"]},
    "stopping_condition": {
      "type": "object",
      "required": ["type", "max_steps"],
      "properties": {
        "type": {"const": "all_steps_completed"},
        "max_steps": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "rollback_plan": {
      "type": "object",
      "required": ["description"],
      "properties": {"description": {"$ref": "#/$defs/nonempty"}},
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "stringList": {
      "type": "array",
      "items": {"$ref": "#/$defs/nonempty"},
      "uniqueItems": true
    },
    "invocation": {
      "type": "object",
      "required": [
        "capability_id", "version", "inputs", "authorities", "provenance",
        "side_effects", "evidence_refs"
      ],
      "properties": {
        "capability_id": {"$ref": "#/$defs/nonempty"},
        "version": {"$ref": "#/$defs/nonempty"},
        "inputs": {"type": "object"},
        "authorities": {"$ref": "#/$defs/stringList"},
        "provenance": {"type": "object"},
        "side_effects": {"$ref": "#/$defs/stringList"},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": [
        "id", "capability_id", "version", "inputs", "authorities",
        "provenance", "side_effects", "evidence_refs", "irreversible"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/nonempty"},
        "capability_id": {"$ref": "#/$defs/nonempty"},
        "version": {"$ref": "#/$defs/nonempty"},
        "inputs": {"type": "object"},
        "authorities": {"$ref": "#/$defs/stringList"},
        "provenance": {"type": "object"},
        "side_effects": {"$ref": "#/$defs/stringList"},
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "irreversible": {"type": "boolean"},
        "rollback": {"$ref": "#/$defs/invocation"}
      },
      "additionalProperties": false
    }
  }
}
